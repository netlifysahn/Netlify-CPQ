it_type":"per_member","price_behavior":"included","list_price":159,"sort_order":3},{"product_id":"id_mmi44qi3_4","name":"Monthly Credits","sku":"CRDT-M","qty":3500,"default_quantity":3500,"unit_type":"per_credit","price_behavior":"included","list_price":0.01333,"sort_order":4},{"product_id":"id_mmjxehen_1","name":"Concurrent Builds","sku":"CC-B","qty":3,"default_quantity":3,"unit_type":"per_build","price_behavior":"related","list_price":40,"sort_order":5}],"created_at":"2026-03-08T19:05:33.439Z","updated_at":"2026-03-10T01:43:42.040Z"},{"id":"id_mmi6wc73_1l","name":"High Performance Edge","sku":"HP-E","description":"","active":true,"hide":false,"category":"platform","type":"platform","is_service":true,"default_term":12,"term_unit":"month","term_behavior":"included","default_price":{"amount":1500,"unit":"flat","pricing_method":"list"},"unit_of_measure":"","default_entitlements":"{}","config":{"lock_quantity":false,"lock_price":false,"lock_discount":false,"lock_term":false,"default_quantity":1,"min_quantity":1,"max_quantity":999,"edit_name":false,"default_description":""},"configuration_method":"none","bundle_pricing":"header_only","print_members":true,"members":[],"components":[],"terms":"Exhibit B\nHigh Performance Edge Service Level Agreement\n      \nDefinitions\n\"Monthly Uptime Percentage\" means the difference between 100% and the percentage of Unavailable Time for the applicable month.\n\"Service Credit\" means a dollar credit, equal to the corresponding % of your High Performance Edge fees in the month in which the Unavailable Time occurred, that Netlify will credit back to your eligible Netlify account.\n\"Unavailable Time\" means the Netlify High Performance Edge is not available for use, as measured in continuous 5-minute increments. Unavailable Time does not include any unavailability resulting from any Exclusion.\n\nService Commitment\nNetlify will make the High Performance Edge available 99.99% of the time each month. If Netlify's Monthly Uptime Percentage is below 99.99% in a given calendar month, then you will be eligible to receive a Service Credit as described in the table below.\n\nSLA Service Credit\n100% - 99.99%: 0%\n< 99.99% - 99.5%: 10%\n< 99.5% - 99.0%: 15%\n< 99.0%: 25%\n\nCredit Request and Payment Procedures\nTo receive a Service Credit, you must submit a request to Netlify Customer Support within thirty (30) days from the time you become eligible to receive the applicable Service Credit.\n\nExclusions\nNo Unavailable Time shall be deemed to have occurred with respect to any unavailability caused by factors outside of Netlify's reasonable control, actions or inactions of you or any third party, Customer Application equipment or software, or alpha/beta features.\n\nEntire SLA Liability\nThis SLA states Netlify's sole and entire liability to you and your sole remedy with respect to Netlify's failure to meet the Monthly Uptime Percentage.","created_at":"2026-03-08T20:13:19.167Z","updated_at":"2026-03-10T16:03:05.200Z"},{"id":"id_mmi6xmrf_1m","name":"High Performance Build","sku":"HP-B","description":"","active":true,"hide":false,"category":"platform","type":"platform","is_service":true,"default_term":12,"term_unit":"month","term_behavior":"included","default_price":{"amount":1500,"unit":"flat","pricing_method":"list"},"unit_of_measure":"","default_entitlements":"{}","config":{"lock_quantity":false,"lock_price":false,"lock_discount":false,"lock_term":false,"default_quantity":1,"min_quantity":1,"max_quantity":999,"edit_name":false,"default_description":""},"configuration_method":"none","bundle_pricing":"header_only","print_members":true,"members":[],"created_at":"2026-03-08T20:14:19.515Z","updated_at":"2026-03-08T20:14:34.666Z"},{"id":"id_mmi77au9_1","name":"Grid","sku":"GRD","description":"Enterprise Team Management","active":true,"hide":false,"category":"addon","type":"addon","is_service":true,"default_term":12,"term_unit":"month","term_behavior":"included","default_price":{"amount":20000,"unit":"flat",